# ── bookit environment ──────────────────────────────────────────
# Copy to .env.local for development and fill in real values.

# Postgres connection string.
#  • Dev: dockerised Postgres → postgres://bookit:bookit@localhost:5434/bookit
#  • Prod (Vercel): Neon POOLED connection string (host ends in -pooler).
DATABASE_URL="postgres://bookit:bookit@localhost:5434/bookit"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Vercel Blob read/write token for image uploads (prod).
# Leave empty in dev to fall back to writing into public/uploads.
# NOTE: required in production — Vercel's filesystem is read-only, so the
# local-disk fallback will fail there.
BLOB_READ_WRITE_TOKEN=""

# Canonical public site URL, used for metadata (OG / canonical links).
#  • Dev: leave unset (defaults to http://localhost:3000).
#  • Prod: set to your real URL, e.g. https://bookit.vercel.app or https://bookit.mk
NEXT_PUBLIC_SITE_URL=""
