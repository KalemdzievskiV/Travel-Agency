# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Generated preview screenshots/video
/preview/*.png
/preview/*.jpg
/preview/*.webm

# Large local hero source videos (keep out of git) — but commit the small,
# web-optimised hero clip so it deploys to the live site.
/public/videos/*
!/public/videos/intro-hero.mp4

# Admin image uploads (dev)
/public/uploads/
